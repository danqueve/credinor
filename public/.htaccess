RewriteEngine On

# Denegar acceso a archivos sensibles
RewriteRule ^(composer\.json|composer\.lock|package\.json|\.env)$ - [F,L]

# Redirigir todo al front controller
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Headers de seguridad
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

# CSP: solo recursos propios + Google Fonts
# 'unsafe-inline' requerido mientras haya <script> inline de Chart.js (pendiente nonces en Fase 4)
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"

# HSTS — solo activo sobre HTTPS
Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
